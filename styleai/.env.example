# ─────────────────────────────────────────────────────────────────
#  STYLEAI  —  Environment Variables
#
#  1. Copy this file:    cp .env.example .env
#  2. Fill in your real values in .env
#  3. NEVER commit .env to GitHub — add it to .gitignore
# ─────────────────────────────────────────────────────────────────

# Flask secret key — any long random string works
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# ── MySQL (you set this up when installing MySQL) ─────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=styleai

# ── Claude API (get from console.anthropic.com) ───────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudinary (free at cloudinary.com) ──────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
